# Kopieer naar .env en vul in. Tokens NOOIT committen of in de chat plakken.
#
# Provider-activatie:
#   - Lege token = provider uitgeschakeld.
#   - Een ingevulde token activeert die bron automatisch.
#   - Bronnen worden NOOIT rechtstreeks aan de frontend getoond; alles loopt via de
#     provider-adapter -> Unified Weather Model -> Decision Engine.

# --- Open-Meteo is de keyless live-basisbron: GEEN key nodig. ---
# Modelkeuze is nu REGIO-GESTUURD (config/regions.json): per locatie kiest de Region Resolver
# de sterkste modellen als aparte bronnen. OPENMETEO_MODEL is enkel nog een globale fallback.
OPENMETEO_MODEL=best_match

# --- Sprint v3.1: tweede onafhankelijke forecast-bron ---
# Vul OPENWEATHER_TOKEN in om de confidence-kruiscontrole te activeren.
OPENWEATHER_TOKEN=

# --- Windy: actieve model-provider (v3.4). Vul je Point-Forecast-key in. ---
# Windy kiest per locatie het regio-model (config/regions.json) en levert o.a. CAPE.
WINDY_TOKEN=

# --- Weerlive: KNMI-meting (observation) voor NL/Vlaanderen. Ijkt de forecasts. ---
# Gratis privé/studie-key via weerlive.nl; alleen actief binnen NL/Vlaanderen.
WEERLIVE_TOKEN=

# --- Nog geen functie ---
WEATHERAPI_TOKEN=
IQAIR_TOKEN=

# Optioneel: contact-e-mail voor Nominatim-geocoding (geen key, alleen netjes).
NOMINATIM_EMAIL=

# Optioneel: serverpoort
PORT=8080
