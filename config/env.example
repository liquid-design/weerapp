# Weerwijsheid runtime environment — voorbeeld.
# Kopieer naar .env (lokaal, in de projectroot) OF naar /opt/weerwijsheid/config/env (VM/systemd).
# Alle tokens zijn OPTIONEEL: leeg = die provider draait op mock met een zichtbare vlag in de UI.
# Regelformaat: KEY=VALUE, # is commentaar. Zet nooit echte tokens in Git.

# --- Server ---
HOST=127.0.0.1                   # bind alleen lokaal; nginx praat met het netwerk (VM). Lokaal testen: 0.0.0.0
PORT=8080                       # backend/app.py luistert op HOST:PORT

# --- Provider-tokens (exacte namen die backend/config.py leest) ---
WINDY_TOKEN=
OPENWEATHER_TOKEN=
WEATHERAPI_TOKEN=
IQAIR_TOKEN=
WEERLIVE_TOKEN=                 # Weerlive = KNMI-observaties (NL)

# --- Geocoding ---
NOMINATIM_EMAIL=                # aanbevolen door Nominatim-beleid; leeg mag, maar wees netjes

# --- Open-Meteo (keyless) ---
OPENMETEO_MODEL=best_match      # best_match | ecmwf_ifs04 | gfs_seamless | icon_seamless | meteofrance_seamless
